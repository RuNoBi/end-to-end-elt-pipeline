# Copy to .env and set your values. Safe to commit (no real secrets).
# Airbyte OSS 0.63.15 — last release with full Docker Compose support.

### VERSION ###
VERSION=0.63.15

### STORAGE / WORKSPACE ###
CONFIG_ROOT=/data
WORKSPACE_ROOT=/tmp/workspace
WORKSPACE_DOCKER_MOUNT=airbyte_workspace
LOCAL_ROOT=/tmp/airbyte_local
LOCAL_DOCKER_MOUNT=oss_local_root
HACK_LOCAL_ROOT_PARENT=/tmp
STORAGE_TYPE=local
STORAGE_BUCKET_ACTIVITY_PAYLOAD=payload-storage
STORAGE_BUCKET_LOG=airbyte-dev-logs
STORAGE_BUCKET_STATE=state-storage
STORAGE_BUCKET_WORKLOAD_OUTPUT=state-storage

### DATABASE (Airbyte internal metadata DB) ###
DATABASE_USER=your_airbyte_db_user
DATABASE_PASSWORD=your_airbyte_db_password_here
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DB=airbyte
DATABASE_URL=jdbc:postgresql://db:5432/airbyte
JOBS_DATABASE_MINIMUM_FLYWAY_MIGRATION_VERSION=0.40.26.001
CONFIGS_DATABASE_MINIMUM_FLYWAY_MIGRATION_VERSION=0.40.23.002

### AIRBYTE SERVICES ###
TEMPORAL_HOST=airbyte-temporal:7233
AIRBYTE_SERVER_HOST=airbyte-server:8001
INTERNAL_API_HOST=http://airbyte-server:8001
AIRBYTE_API_HOST=airbyte-server:8001
CONNECTOR_BUILDER_API_HOST=airbyte-connector-builder-server:8080
WEBAPP_URL=http://localhost:8000/
DEPLOYMENT_MODE=OSS
WORKER_ENVIRONMENT=docker
DOCKER_NETWORK=de_poc_network

### PROXY (optional basic auth on UI) ###
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
BASIC_AUTH_PROXY_TIMEOUT=900

### JOBS ###
SYNC_JOB_MAX_ATTEMPTS=3
SYNC_JOB_MAX_TIMEOUT_DAYS=3
JOB_MAIN_CONTAINER_CPU_REQUEST=
JOB_MAIN_CONTAINER_CPU_LIMIT=
JOB_MAIN_CONTAINER_MEMORY_REQUEST=
JOB_MAIN_CONTAINER_MEMORY_LIMIT=

### LOGGING ###
LOG_LEVEL=INFO
TRACKING_STRATEGY=logging

### APPLICATIONS ###
SERVER_MICRONAUT_ENVIRONMENTS=control-plane
WORKERS_MICRONAUT_ENVIRONMENTS=control-plane
CRON_MICRONAUT_ENVIRONMENTS=control-plane
MAX_SYNC_WORKERS=5
MAX_CHECK_WORKERS=5

### FEATURE FLAGS ###
AUTO_DISABLE_FAILING_CONNECTIONS=false
AUTO_DETECT_SCHEMA=true
SECRET_PERSISTENCE=TESTING_CONFIG_DB_TABLE
TEMPORAL_HISTORY_RETENTION_IN_DAYS=30
