# Copy: cp .env.example .env
# After first start: ./scripts/bootstrap-ckan.sh (writes CKAN_API_TOKEN into .env)

# --- Postgres (CKAN metadata + datastore — NOT the analytics warehouse) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_ckan_postgres_password_here
POSTGRES_DB=postgres

CKAN_DB_USER=ckandbuser
CKAN_DB_PASSWORD=your_ckan_db_password_here
CKAN_DB=ckandb
DATASTORE_DB=datastore
DATASTORE_READONLY_USER=datastore_ro
DATASTORE_READONLY_PASSWORD=your_datastore_ro_password_here

# --- CKAN site (localhost) ---
CKAN_PORT_HOST=5001
CKAN_SITE_URL=http://localhost:5001
CKAN_SYSADMIN_NAME=ckan_admin
CKAN_SYSADMIN_PASSWORD=your_ckan_admin_password_here
CKAN_SYSADMIN_EMAIL=admin@localhost

# Filled by bootstrap-ckan.sh — leave empty until then
CKAN_API_TOKEN=

CKAN_ORGANIZATION=ube-group-thailand
CKAN_ORGANIZATION_TITLE=UBE Group Thailand
CKAN_SITE_TITLE=UBE Group Thailand — Data Catalog
CKAN_SITE_DESCRIPTION=Enterprise Gold datamarts from the ELT platform (Airbyte, dbt, Airflow).
