# Copy: cp .env.example .env
# Generate Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Airflow internal metadata database (not the warehouse) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_airflow_metadata_password_here
POSTGRES_DB=airflow

AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=your_airflow_ui_password_here
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User

# --- Airbyte OSS 0.63 API (DAG uses /api/v1/connections/sync, not Cloud /jobs API) ---
AIRFLOW_VAR_AIRBYTE_CONNECTION_ID=b84b53a7-abfa-4c29-9f6b-c663dd0f4283
AIRFLOW_VAR_AIRBYTE_API_BASE_URL=http://airbyte-proxy:8000/api/v1

# --- Must match warehouse-postgres/.env ---
DBT_WAREHOUSE_HOST=de_poc_warehouse_postgres
DBT_WAREHOUSE_PORT=5432
DBT_WAREHOUSE_USER=your_warehouse_db_user
DBT_WAREHOUSE_PASSWORD=your_warehouse_db_password_here
DBT_WAREHOUSE_DB=data_warehouse
DBT_WAREHOUSE_SCHEMA=gold
DBT_THREADS=4
